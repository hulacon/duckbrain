#!/usr/bin/env bash

# NOTE: ERB evaluates this whole file at submit time, even inside bash comments.
# Do NOT put ERB tags here (they would run against TemplateBinding, where the
# connection host is not yet defined, and abort submission).

# The OOD basic-template wrapper already exports `host=$(hostname)` before it
# sources this file; we set it again defensively so connection.yml always has it.
export host=$(hostname)

# Find an available port for Streamlit
export port=$(find_port "${host}")

# OOD expects a password variable (Streamlit doesn't use it, but set it anyway)
export password="$(create_passwd 16)"
