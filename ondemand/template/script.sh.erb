#!/bin/bash -l
# NOTE: must be `#!/bin/bash -l`, NOT `#!/usr/bin/env bash -l` — env treats
# "bash -l" as a single program name and fails ("No such file or directory"),
# which kills the job before Streamlit starts.

set -x

# Resolve the install dir at runtime so shell tokens in the form value expand.
# Handles the legacy `%{ENV:USER}` default (which OOD does NOT interpolate),
# plus $USER / ${USER} / ~ in whatever the user typed.
RAW_DUCKBRAIN_DIR="<%= context.duckbrain_dir %>"
RAW_DUCKBRAIN_DIR="${RAW_DUCKBRAIN_DIR//%\{ENV:USER\}/$USER}"
DUCKBRAIN_DIR=$(eval echo "${RAW_DUCKBRAIN_DIR}")

echo "=== duckbrain OOD session ==="
echo "Node: $(hostname)"
echo "Port: ${port}"
echo "duckbrain dir: ${DUCKBRAIN_DIR}"

# Activate the venv if it exists
if [ -f "${DUCKBRAIN_DIR}/.venv/bin/activate" ]; then
    source "${DUCKBRAIN_DIR}/.venv/bin/activate"
else
    # Fall back to loading a conda/python module
    module load python3 2>/dev/null || module load miniconda3 2>/dev/null || true
fi

# Set config directory (shipped base.toml defaults)
export DUCKBRAIN_CONFIG_DIR="${DUCKBRAIN_DIR}/config"

# Optionally pre-select a project directory (expand $USER / ~ at runtime)
RAW_PROJECT_DIR="<%= context.project_dir %>"
if [ -n "${RAW_PROJECT_DIR}" ]; then
    export DUCKBRAIN_PROJECT_DIR=$(eval echo "${RAW_PROJECT_DIR}")
    echo "duckbrain project dir: ${DUCKBRAIN_PROJECT_DIR}"
fi

# Ensure duckbrain is importable (editable install or add to path)
if python -c "import duckbrain" 2>/dev/null; then
    echo "duckbrain package found"
else
    echo "Installing duckbrain in editable mode..."
    pip install -e "${DUCKBRAIN_DIR}" --quiet
fi

# Launch Streamlit behind OOD's reverse proxy
# --server.baseUrlPath must match OOD's /node/<host>/<port>/ proxy path
streamlit run "${DUCKBRAIN_DIR}/src/duckbrain/gui/app.py" \
    --server.port="${port}" \
    --server.address="0.0.0.0" \
    --server.headless=true \
    --server.enableCORS=false \
    --server.enableXsrfProtection=false \
    --server.baseUrlPath="/node/$(hostname)/${port}/" \
    --browser.gatherUsageStats=false
