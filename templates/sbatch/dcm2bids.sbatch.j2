#!/bin/bash
#SBATCH --job-name=dcm2bids_{{ subject }}{% if session %}_{{ session }}{% endif %}
#SBATCH --partition={{ slurm.partition }}
#SBATCH --time={{ slurm.time }}
#SBATCH --cpus-per-task={{ slurm.cpus }}
#SBATCH --mem={{ slurm.memory }}
#SBATCH --output={{ paths.log_dir }}/dcm2bids_%j.out
{% if slurm.email %}#SBATCH --mail-user={{ slurm.email }}
#SBATCH --mail-type={{ slurm.mail_type }}
{% endif %}{% if slurm.account %}#SBATCH --account={{ slurm.account }}
{% endif %}
echo "=== dcm2bids: sub-{{ subject }}{% if session %} ses-{{ session }}{% endif %} ==="
echo "Started: $(date)"
echo "Node: $(hostname)"

{# Every interpolation below is ONE shell argument, so every one carries `| sh`.
   A bind spec is built and quoted whole: source:destination:mode is a single
   argument to singularity, not three. #}
singularity run --cleanenv \
  -B {{ (dicom_dir ~ ":" ~ dicom_dir ~ ":ro") | sh }} \
  -B {{ (paths.bids_dir ~ ":" ~ paths.bids_dir) | sh }} \
  -B {{ (config_json_dir ~ ":" ~ config_json_dir ~ ":ro") | sh }} \
  {{ container_path | sh }} \
  -d {{ dicom_dir | sh }} \
  -p {{ subject | sh }} \
{% if session %}  -s {{ session | sh }} \
{% endif %}  -c {{ config_json | sh }} \
  -o {{ paths.bids_dir | sh }} \
  {% if bids_validate %}--bids_validate {% endif %}{% if force %}--force_dcm2bids{% endif %}

EXIT_CODE=$?
echo "Finished: $(date)"
echo "Exit code: $EXIT_CODE"
exit $EXIT_CODE
