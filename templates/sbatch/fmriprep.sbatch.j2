#!/bin/bash
#SBATCH --job-name=fmriprep_{{ subject }}{% if session %}_{{ session }}{% endif %}
#SBATCH --partition={{ slurm.partition }}
#SBATCH --time={{ slurm.time }}
#SBATCH --cpus-per-task={{ slurm.cpus }}
#SBATCH --mem={{ slurm.memory }}
#SBATCH --output={{ paths.work_dir }}/logs/fmriprep_%j.out
{% if slurm.email %}#SBATCH --mail-user={{ slurm.email }}
#SBATCH --mail-type={{ slurm.mail_type }}
{% endif %}{% if slurm.account %}#SBATCH --account={{ slurm.account }}
{% endif %}
echo "=== fMRIPrep: sub-{{ subject }}{% if session %} ses-{{ session }}{% endif %} ==="
echo "Started: $(date)"
echo "Node: $(hostname)"

export SINGULARITYENV_TEMPLATEFLOW_HOME={{ paths.work_dir }}/templateflow
export SINGULARITY_TMPDIR={{ paths.work_dir }}/tmp
mkdir -p $SINGULARITYENV_TEMPLATEFLOW_HOME $SINGULARITY_TMPDIR

WORK_DIR={{ paths.work_dir }}/sub-{{ subject }}{% if session %}_ses-{{ session }}{% endif %}
mkdir -p $WORK_DIR

singularity run --cleanenv \
  -B {{ bids_dir }}:{{ bids_dir }}:ro \
  -B {{ output_dir }}:{{ output_dir }} \
  -B $WORK_DIR:$WORK_DIR \
  -B {{ fs_license_dir }}:{{ fs_license_dir }}:ro \
{% if derivatives %}  -B {{ derivatives }}:{{ derivatives }}:ro \
{% endif %}  {{ container_path }} \
  {{ bids_dir }} {{ output_dir }} participant \
  --participant-label {{ subject }} \
{% if filter_file %}  --bids-filter-file {{ filter_file }} \
{% endif %}  --output-spaces {{ output_spaces | join(' ') }} \
  --fs-license-file {{ fs_license }} \
  --nprocs {{ fmriprep.nprocs }} \
  --mem-mb {{ fmriprep.mem_gb * 1024 }} \
  -w $WORK_DIR \
{% if anat_only %}  --anat-only \
{% endif %}{% if derivatives %}  --derivatives {{ derivatives }} \
{% endif %}  --skip-bids-validation --notrack

EXIT_CODE=$?
echo "Finished: $(date)"
echo "Exit code: $EXIT_CODE"
exit $EXIT_CODE
