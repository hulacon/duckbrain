#!/bin/bash
#SBATCH --job-name=mriqc_{{ subject }}{% if session %}_{{ session }}{% endif %}
#SBATCH --partition={{ slurm.partition }}
#SBATCH --time={{ slurm.time }}
#SBATCH --cpus-per-task={{ slurm.cpus }}
#SBATCH --mem={{ slurm.memory }}
#SBATCH --output={{ paths.log_dir }}/mriqc_%j.out
{% if slurm.email %}#SBATCH --mail-user={{ slurm.email }}
#SBATCH --mail-type={{ slurm.mail_type }}
{% endif %}{% if slurm.account %}#SBATCH --account={{ slurm.account }}
{% endif %}
echo "=== MRIQC: sub-{{ subject }}{% if session %} ses-{{ session }}{% endif %} ==="
echo "Started: $(date)"
echo "Node: $(hostname)"

{# Paths carry `| sh` — one interpolation, one shell argument. Expansions need
   their own quotes; the filter protects the assignment, not each later use. #}
WORK_DIR={{ (paths.work_dir ~ "/mriqc_sub-" ~ subject ~ ("_ses-" ~ session if session else "")) | sh }}
OUTPUT_DIR={{ (paths.derivatives_dir ~ "/mriqc") | sh }}
mkdir -p "$WORK_DIR" "$OUTPUT_DIR"

singularity run --cleanenv \
  -B {{ (paths.bids_dir ~ ":" ~ paths.bids_dir ~ ":ro") | sh }} \
  -B "$OUTPUT_DIR:$OUTPUT_DIR" \
  -B "$WORK_DIR:$WORK_DIR" \
  {{ container_path | sh }} \
  {{ paths.bids_dir | sh }} "$OUTPUT_DIR" participant \
  --participant-label {{ subject | sh }} \
{% if session %}  --session-id {{ session | sh }} \
{% endif %}  --nprocs {{ slurm.cpus }} \
  --mem-gb {{ mem_gb }} \
  -w "$WORK_DIR" \
  --no-sub

EXIT_CODE=$?
echo "Finished: $(date)"
echo "Exit code: $EXIT_CODE"
exit $EXIT_CODE
