#!/bin/bash
#SBATCH --job-name=nordic_{{ subject }}{% if session %}_{{ session }}{% endif %}
#SBATCH --partition={{ slurm.partition }}
#SBATCH --time={{ slurm.time }}
#SBATCH --cpus-per-task={{ slurm.cpus }}
#SBATCH --mem={{ slurm.memory }}
#SBATCH --output={{ paths.log_dir }}/nordic_%A_%a.out
#SBATCH --array=1-{{ bold_count }}
{% if slurm.email %}#SBATCH --mail-user={{ slurm.email }}
#SBATCH --mail-type={{ slurm.mail_type }}
{% endif %}{% if slurm.account %}#SBATCH --account={{ slurm.account }}
{% endif %}{% if nordic.excluded_nodes %}#SBATCH --exclude={{ nordic.excluded_nodes }}
{% endif %}
echo "=== NORDIC denoise: sub-{{ subject }}{% if session %} ses-{{ session }}{% endif %} (task ${SLURM_ARRAY_TASK_ID}) ==="
echo "Started: $(date)"
echo "Node: $(hostname)"

# Discover BOLD runs. Paths carry `| sh` — one interpolation, one shell argument
# — and every expansion of them is quoted in turn.
FUNC_DIR={{ (paths.bids_dir ~ "/sub-" ~ subject ~ ("/ses-" ~ session if session else "") ~ "/func") | sh }}
BOLD_FILES=($(ls "${FUNC_DIR}"/*_bold.nii.gz 2>/dev/null | sort))
# Count via wc, not a bash array-length expansion: the hash-brace token in
# that expansion collides with Jinja's comment-open and breaks rendering.
NUM_RUNS=$(ls "${FUNC_DIR}"/*_bold.nii.gz 2>/dev/null | wc -l)

if [ $NUM_RUNS -eq 0 ]; then
    echo "ERROR: No BOLD files found in ${FUNC_DIR}"
    exit 1
fi

# Select run for this array task
IDX=$((SLURM_ARRAY_TASK_ID - 1))
BOLD_IN=${BOLD_FILES[$IDX]}
echo "Processing: $BOLD_IN"

# Output directory
OUT_DIR={{ (paths.derivatives_dir ~ "/nordic/sub-" ~ subject ~ ("/ses-" ~ session if session else "") ~ "/func") | sh }}
mkdir -p "$OUT_DIR"

# Check if already processed
BOLD_BASENAME=$(basename "$BOLD_IN")
if [ -f "${OUT_DIR}/${BOLD_BASENAME}" ]; then
    echo "Output already exists, skipping: ${OUT_DIR}/${BOLD_BASENAME}"
    exit 0
fi

# Run NORDIC via MATLAB.
#
# Paths reach MATLAB through getenv, not through the -r string. That string is
# bash-double-quoted and held MATLAB single-quoted literals — the same two-layer
# substitution as nordic_bids_input, where an apostrophe in a path escapes the
# MATLAB literal and a `$` is eaten by bash first. getenv has neither layer.
export DUCKBRAIN_NORDIC_TOOLBOX={{ paths.nordic_toolbox_dir | sh }}
export DUCKBRAIN_SCRIPTS_DIR={{ scripts_dir | sh }}
export DUCKBRAIN_BOLD_IN="$BOLD_IN"
export DUCKBRAIN_OUT_DIR="$OUT_DIR"

module load {{ nordic.matlab_module | sh }}

matlab -nodisplay -nosplash -nodesktop -r "\
    addpath(getenv('DUCKBRAIN_NORDIC_TOOLBOX')); \
    addpath(getenv('DUCKBRAIN_SCRIPTS_DIR')); \
    nordic_denoise(getenv('DUCKBRAIN_BOLD_IN'), getenv('DUCKBRAIN_OUT_DIR')); \
    exit;"

EXIT_CODE=$?
echo "Finished: $(date)"
echo "Exit code: $EXIT_CODE"
exit $EXIT_CODE
